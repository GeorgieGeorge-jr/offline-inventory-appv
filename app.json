{
  "expo": {
    "name": "Offline Inventory",
    "slug": "offline-inventory-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6200ee"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Offline Inventory to access your camera",
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.offlineinventory",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Offline Inventory to use the camera for barcode and QR code scanning."
      }
    },
    "android": {
      "package": "com.offlineinventory",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#6200ee"
      }
    },
    "extra": {
      "eas": {
        "projectId": "80cf494b-2734-458f-a2d0-42c54fda93fd"
      }
    }
  }
}
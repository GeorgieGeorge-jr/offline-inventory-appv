{
  "expo": {
    "name": "Genova",
    "slug": "offline-inventory-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Genova to access your camera",
          "barcodeScannerEnabled": true
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.genova.inventory",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Genova to use the camera for barcode and QR code scanning."
      }
    },
    "android": {
      "package": "com.genova.inventory",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#7C3AED"
      }
    },
    "extra": {
      "eas": {
        "projectId": "80cf494b-2734-458f-a2d0-42c54fda93fd"
      }
    }
  }
}